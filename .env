# Role flags
IS_VALIDATOR=true
IS_RPC_NODE=true

# File paths
VALIDATOR_LOG_FILE=/home/user/supra/supra_node.log
RPC_LOG_FILE=/home/user/supra_rpc/rpc_node.log

# RPC URLs
VALIDATOR_RPC_URL=http://localhost:27000/rpc/v1
RPC_NODE_URL=http://localhost:27001/rpc/v1

# Exporter
EXPORTER_PORT=7896
POLL_INTERVAL=10
NETWORK_PUBKEY=abcd1234...
